{
  "name": "mobile-ui-generator-react-native-harness",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start --offline",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "ios:build": "expo run:ios --no-install --device \"iPhone 15\"",
    "android:build": "expo run:android --no-install",
    "prebuild": "expo prebuild --no-install",
    "capture:ios": "node scripts/capture-ios.mjs",
    "capture:android": "node scripts/capture-android.mjs",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "expo": "51.0.39",
    "react": "18.2.0",
    "react-native": "0.74.7",
    "react-native-safe-area-context": "4.10.5"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/node": "22.15.3",
    "@types/react": "18.2.79",
    "@types/react-test-renderer": "18.0.7",
    "jest": "29.7.0",
    "jest-expo": "51.0.4",
    "react-test-renderer": "18.2.0",
    "typescript": "5.8.3"
  },
  "engines": {
    "node": ">=22.13 <23"
  }
}
