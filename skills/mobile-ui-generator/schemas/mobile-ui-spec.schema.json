{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jinyoung89.github.io/mobile-ui-generator-skill/schemas/mobile-ui-spec.schema.json",
  "title": "Canonical Mobile UI Specification",
  "description": "Versioned, numeric source of truth for all four public platform outputs.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "request", "classification", "platform_policy", "layout", "typography", "colors", "components", "states", "interactions", "responsive_rules", "accessibility", "content", "assets_and_fallbacks", "fixture_data", "navigation_and_actions", "validation_rules", "focus_and_keyboard", "localization", "themes", "capabilities_and_dependencies", "platform_mappings", "quality_requirements"],
  "properties": {
    "schema_version": {"const": 1},
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]{2,96}$"},
    "request": {"$ref": "#/$defs/request"},
    "classification": {"$ref": "#/$defs/classification"},
    "platform_policy": {"$ref": "#/$defs/platformPolicy"},
    "layout": {"$ref": "#/$defs/layout"},
    "typography": {"type": "object", "additionalProperties": false, "required": ["roles"], "properties": {"roles": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/typographyRole"}}}},
    "colors": {"$ref": "#/$defs/colors"},
    "components": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/component"}},
    "states": {"type": "object", "additionalProperties": false, "required": ["screen", "inputs", "cta"], "properties": {"screen": {"$ref": "#/$defs/stringArray"}, "inputs": {"$ref": "#/$defs/stringArray"}, "cta": {"$ref": "#/$defs/stringArray"}}},
    "interactions": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["id", "source", "event", "action"], "properties": {"id": {"type": "string"}, "source": {"type": "string"}, "event": {"type": "string"}, "action": {"type": "string"}}}},
    "responsive_rules": {"type": "array", "minItems": 3, "items": {"$ref": "#/$defs/responsiveRule"}},
    "accessibility": {"$ref": "#/$defs/accessibility"},
    "content": {"type": "object", "additionalProperties": false, "required": ["locales", "fixtures"], "properties": {"locales": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "object", "minProperties": 1}}, "fixtures": {"$ref": "#/$defs/stringArray"}}},
    "assets_and_fallbacks": {"type": "object", "additionalProperties": false, "required": ["assets", "fallback_policy"], "properties": {"assets": {"type": "array", "items": {"type": "string"}}, "fallback_policy": {"type": "string", "minLength": 1}}},
    "fixture_data": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "object"}},
    "navigation_and_actions": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/navigationAction"}},
    "validation_rules": {"$ref": "#/$defs/validationRules"},
    "focus_and_keyboard": {"type": "object", "additionalProperties": false, "required": ["focusable_components", "keyboard_behavior", "primary_action_visible"], "properties": {"focusable_components": {"$ref": "#/$defs/stringArray"}, "keyboard_behavior": {"type": "string", "minLength": 1}, "primary_action_visible": {"const": true}}},
    "localization": {"type": "object", "additionalProperties": false, "required": ["default_language", "supported_languages", "fallback_language", "long_copy_profiles"], "properties": {"default_language": {"type": "string"}, "supported_languages": {"$ref": "#/$defs/stringArray"}, "fallback_language": {"type": "string"}, "long_copy_profiles": {"$ref": "#/$defs/stringArray"}}},
    "themes": {"type": "object", "additionalProperties": false, "required": ["supported", "default"], "properties": {"supported": {"$ref": "#/$defs/stringArray"}, "default": {"type": "string"}}},
    "capabilities_and_dependencies": {"type": "object", "additionalProperties": false, "required": ["network", "authentication", "payment_execution", "push", "fixture_only"], "properties": {"network": {"type": "boolean"}, "authentication": {"type": "boolean"}, "payment_execution": {"type": "boolean"}, "push": {"type": "boolean"}, "fixture_only": {"const": true}}},
    "platform_mappings": {"type": "object", "additionalProperties": false, "required": ["html_css", "react_native", "flutter", "swiftui"], "properties": {"html_css": {"$ref": "#/$defs/platformMappingPx"}, "react_native": {"$ref": "#/$defs/platformMappingDp"}, "flutter": {"$ref": "#/$defs/platformMappingDp"}, "swiftui": {"$ref": "#/$defs/platformMappingPt"}}},
    "quality_requirements": {"type": "object", "additionalProperties": false, "required": ["numeric_spec_validated", "responsive_profiles", "all_states_fixture_backed", "platform_parity_report"], "properties": {"numeric_spec_validated": {"const": true}, "responsive_profiles": {"type": "array", "contains": {"const": 320}, "minItems": 3, "uniqueItems": true, "items": {"type": "integer", "minimum": 1}}, "all_states_fixture_backed": {"const": true}, "platform_parity_report": {"const": true}}}
  },
  "$defs": {
    "stringArray": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "measure": {
      "type": "object", "additionalProperties": false, "minProperties": 1, "maxProperties": 4,
      "oneOf": [
        {"required": ["value", "unit"], "properties": {"value": {"type": "number"}, "unit": {"enum": ["px", "pt", "dp", "sp", "ratio"]}}},
        {"required": ["token"], "properties": {"token": {"type": "string", "minLength": 1}}},
        {"required": ["formula", "unit", "min", "max"], "properties": {"formula": {"type": "string", "minLength": 1}, "unit": {"enum": ["px", "pt", "dp", "sp", "ratio"]}, "min": {"type": "number"}, "max": {"type": "number"}}}
      ]
    },
    "request": {"type": "object", "additionalProperties": false, "required": ["language", "user_job"], "properties": {"language": {"type": "string", "minLength": 2}, "user_job": {"type": "string", "minLength": 1}}},
    "classification": {"type": "object", "additionalProperties": false, "required": ["app_category", "ui_patterns", "risk_level"], "properties": {"app_category": {"type": "string", "minLength": 1}, "ui_patterns": {"$ref": "#/$defs/stringArray"}, "risk_level": {"enum": ["low", "medium", "high"]}}},
    "platformPolicy": {"type": "object", "additionalProperties": false, "required": ["reference_viewport_width", "supported_width_range", "safe_area", "token_resolution_order", "rounding", "constraint_precedence"], "properties": {"reference_viewport_width": {"type": "integer", "minimum": 1}, "supported_width_range": {"type": "object", "additionalProperties": false, "required": ["min", "max"], "properties": {"min": {"type": "integer", "minimum": 1}, "max": {"type": "integer", "minimum": 1}}}, "safe_area": {"type": "object", "additionalProperties": false, "required": ["top", "bottom", "unit", "mode"], "properties": {"top": {"type": "number", "minimum": 0}, "bottom": {"type": "number", "minimum": 0}, "unit": {"const": "px"}, "mode": {"type": "string", "minLength": 1}}}, "token_resolution_order": {"$ref": "#/$defs/stringArray"}, "rounding": {"type": "object", "additionalProperties": false, "required": ["html_css", "react_native", "flutter", "swiftui"], "properties": {"html_css": {"enum": ["nearest", "floor", "ceil"]}, "react_native": {"enum": ["nearest", "floor", "ceil"]}, "flutter": {"enum": ["nearest", "floor", "ceil"]}, "swiftui": {"enum": ["nearest", "floor", "ceil"]}}}, "constraint_precedence": {"const": ["safe_area", "fixed_region", "min_max", "content"]}}},
    "tokenMap": {"type": "object", "minProperties": 1, "additionalProperties": {"$ref": "#/$defs/measure"}},
    "layout": {"type": "object", "additionalProperties": false, "required": ["tokens", "screen_horizontal_inset", "grid", "alignment_anchors", "component_gap", "section_gap", "card_padding", "control_height", "corner_radius", "sticky_region_height", "scroll_content_bottom_inset", "max_readable_line_width", "image_aspect_ratios", "constraints"], "properties": {"tokens": {"$ref": "#/$defs/tokenMap"}, "screen_horizontal_inset": {"$ref": "#/$defs/measure"}, "grid": {"type": "object", "additionalProperties": false, "required": ["columns", "gutter"], "properties": {"columns": {"type": "integer", "minimum": 1}, "gutter": {"$ref": "#/$defs/measure"}}}, "alignment_anchors": {"$ref": "#/$defs/stringArray"}, "component_gap": {"$ref": "#/$defs/measure"}, "section_gap": {"$ref": "#/$defs/measure"}, "card_padding": {"$ref": "#/$defs/measure"}, "control_height": {"$ref": "#/$defs/measure"}, "corner_radius": {"$ref": "#/$defs/measure"}, "sticky_region_height": {"$ref": "#/$defs/measure"}, "scroll_content_bottom_inset": {"$ref": "#/$defs/measure"}, "max_readable_line_width": {"$ref": "#/$defs/measure"}, "image_aspect_ratios": {"type": "object", "additionalProperties": {"type": "object", "additionalProperties": false, "required": ["width", "height", "crop"], "properties": {"width": {"type": "number", "exclusiveMinimum": 0}, "height": {"type": "number", "exclusiveMinimum": 0}, "crop": {"enum": ["cover", "contain", "fill"]}}}}, "constraints": {"type": "object", "additionalProperties": false, "required": ["precedence"], "properties": {"precedence": {"const": ["safe_area", "fixed_region", "min_max", "content"]}}}}},
    "typographyRole": {"type": "object", "additionalProperties": false, "required": ["id", "font_family", "size", "line_height", "weight", "max_lines", "overflow", "text_scale_policy", "min_contrast_ratio"], "properties": {"id": {"type": "string"}, "font_family": {"type": "string"}, "size": {"$ref": "#/$defs/measure"}, "line_height": {"$ref": "#/$defs/measure"}, "weight": {"type": "integer", "minimum": 100, "maximum": 1000}, "letter_spacing": {"$ref": "#/$defs/measure"}, "max_lines": {"type": "integer", "minimum": 1}, "overflow": {"type": "string"}, "text_scale_policy": {"type": "string"}, "min_contrast_ratio": {"type": "number", "minimum": 1}}},
    "colors": {"type": "object", "additionalProperties": false, "required": ["tokens", "contrast_pairs"], "properties": {"tokens": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "string", "pattern": "^#[0-9A-Fa-f]{6,8}$"}}, "contrast_pairs": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["foreground", "background", "minimum_ratio"], "properties": {"foreground": {"type": "string"}, "background": {"type": "string"}, "minimum_ratio": {"type": "number", "minimum": 1}}}}}},
    "component": {"type": "object", "additionalProperties": false, "required": ["id", "role", "parent", "order", "layout", "states", "default_state", "interaction", "accessibility", "platform_native_substitution"], "properties": {"id": {"type": "string"}, "role": {"type": "string"}, "parent": {"type": ["string", "null"]}, "order": {"type": "integer", "minimum": 0}, "layout": {"type": "object", "additionalProperties": false, "required": ["width", "height", "padding", "gap", "alignment"], "properties": {"width": {"oneOf": [{"$ref": "#/$defs/measure"}, {"enum": ["fill", "content"]}]}, "height": {"oneOf": [{"$ref": "#/$defs/measure"}, {"enum": ["fill", "content"]}]}, "padding": {"$ref": "#/$defs/measure"}, "gap": {"$ref": "#/$defs/measure"}, "alignment": {"type": "string"}}}, "states": {"$ref": "#/$defs/stringArray"}, "default_state": {"type": "string"}, "text_roles": {"$ref": "#/$defs/stringArray"}, "interaction": {"type": "object", "additionalProperties": false, "required": ["kind"], "properties": {"kind": {"type": "string"}, "focusable": {"type": "boolean"}}}, "accessibility": {"$ref": "#/$defs/accessibilityComponent"}, "platform_native_substitution": {"type": "string", "minLength": 1}}},
    "accessibilityComponent": {"type": "object", "additionalProperties": false, "required": ["label", "target_size"], "properties": {"label": {"type": "string", "minLength": 1}, "target_size": {"type": "object", "additionalProperties": false, "required": ["width", "height", "unit"], "properties": {"width": {"type": "number", "minimum": 44}, "height": {"type": "number", "minimum": 44}, "unit": {"enum": ["px", "pt", "dp"]}}}}},
    "responsiveRule": {"type": "object", "additionalProperties": false, "required": ["width", "changes", "no_horizontal_overflow", "fixed_regions_preserve_inset"], "properties": {"width": {"type": "object", "additionalProperties": false, "required": ["min", "max"], "properties": {"min": {"type": "integer", "minimum": 1}, "max": {"type": "integer", "minimum": 1}}}, "changes": {"$ref": "#/$defs/stringArray"}, "no_horizontal_overflow": {"const": true}, "fixed_regions_preserve_inset": {"const": true}}},
    "accessibility": {"type": "object", "additionalProperties": false, "required": ["minimum_contrast_ratio", "minimum_touch_target", "screen_reader", "reduced_motion", "dynamic_text"], "properties": {"minimum_contrast_ratio": {"type": "number", "minimum": 4.5}, "minimum_touch_target": {"$ref": "#/$defs/accessibilityComponent/properties/target_size"}, "screen_reader": {"type": "string"}, "reduced_motion": {"type": "string"}, "dynamic_text": {"type": "string"}}},
    "navigationAction": {"type": "object", "additionalProperties": false, "required": ["id", "source_component", "outcome"], "properties": {"id": {"type": "string"}, "source_component": {"type": "string"}, "outcome": {"type": "object", "additionalProperties": false, "required": ["kind"], "properties": {"kind": {"enum": ["local_state", "local_screen", "local_modal", "fixture_result"]}, "state": {"type": "string"}, "target": {"type": "string"}, "fixture": {"type": "string"}}}}},
    "validationRules": {"type": "object", "additionalProperties": false, "required": ["no_horizontal_overflow", "no_overlap", "safe_area_respected", "fixed_regions_do_not_cover_content", "required_states_renderable"], "properties": {"no_horizontal_overflow": {"const": true}, "no_overlap": {"const": true}, "safe_area_respected": {"const": true}, "fixed_regions_do_not_cover_content": {"const": true}, "required_states_renderable": {"const": true}}},
    "platformMapping": {"type": "object", "additionalProperties": false, "required": ["unit", "safe_area", "rounding", "native_substitutions_explicit"], "properties": {"unit": {"enum": ["px", "pt", "dp", "sp"]}, "safe_area": {"type": "string", "minLength": 1}, "rounding": {"enum": ["nearest", "floor", "ceil"]}, "native_substitutions_explicit": {"const": true}}},
    "platformMappingPx": {"allOf": [{"$ref": "#/$defs/platformMapping"}, {"properties": {"unit": {"const": "px"}}}]},
    "platformMappingDp": {"allOf": [{"$ref": "#/$defs/platformMapping"}, {"properties": {"unit": {"const": "dp"}}}]},
    "platformMappingPt": {"allOf": [{"$ref": "#/$defs/platformMapping"}, {"properties": {"unit": {"const": "pt"}}}]}
  }
}
