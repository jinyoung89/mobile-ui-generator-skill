{
  "name": "mobile-ui-generator",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "test": "node tooling/scripts/run-tests.mjs",
    "typecheck": "tsc --noEmit",
    "export:public-knowledge": "tsx tooling/src/export-public-knowledge.ts",
    "validate:spec": "tsx tooling/src/validate-spec.ts",
    "validate:catalog": "tsx tooling/src/validate-catalog.ts",
    "validate:boundary": "tsx tooling/src/check-public-boundary.ts",
    "validate:images": "tsx tooling/src/check-image-similarity.ts",
    "compile:example": "tsx tooling/src/compile-example.ts",
    "evaluate:skill": "tsx tooling/src/evaluate-skill.ts --contract-smoke",
    "validate:baseline": "python3 scripts/validate_patterns.py && python3 scripts/validate_site.py && npm test && npm run typecheck",
    "preflight:mobile": "tooling/scripts/verify-mobile-targets.sh",
    "build:site": "node tooling/scripts/not-implemented.mjs build:site",
    "verify": "node tooling/scripts/not-implemented.mjs verify"
  },
  "devDependencies": {
    "@types/node": "22.15.3",
    "ajv": "^8.18.0",
    "tsx": "4.19.4",
    "typescript": "5.8.3"
  }
}
