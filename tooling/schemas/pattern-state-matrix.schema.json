{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://mobile-ui-generator.dev/schema/pattern-state-matrix-1.0.0.json",
  "type":"object","additionalProperties":false,
  "required":["schema_version","matrix_version","state_catalog","state_transitions","entries"],
  "properties":{
    "schema_version":{"const":"1.0.0"},
    "matrix_version":{"type":"string","minLength":1},
    "state_catalog":{"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"string","pattern":"^[a-z][a-z0-9_]*$"}},
    "state_transitions":{"type":"array","const":[{"from":"proposed","to":"approved"},{"from":"approved","to":"generated"},{"from":"generated","to":"build_verified"},{"from":"build_verified","to":"render_verified"},{"from":"render_verified","to":"published"}]},
    "entries":{"type":"array","minItems":1,"items":{"$ref":"#/$defs/entry"}}
  },
  "$defs":{
    "entry":{"type":"object","additionalProperties":false,"required":["ui_pattern","states"],"properties":{"ui_pattern":{"type":"string","pattern":"^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"},"states":{"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"object","additionalProperties":false,"required":["id","applicability"],"properties":{"id":{"type":"string","pattern":"^[a-z][a-z0-9_]*$"},"applicability":{"enum":["required","optional","not_applicable"]}}}}}}
  }
}
